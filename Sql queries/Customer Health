                                                                                                              Q9.Business question
                                                                                                   Do support tickets increase churn likelihood?
                   Query
SELECT
	CASE
	WHEN support_tickets BETWEEN 0 AND 3 THEN 'low_ticket'
	WHEN support_tickets BETWEEN 4 AND 6 THEN 'moderate_ticket'
	ELSE 'high_ticket'
	END AS issued_ticket,
	COUNT(*)total_users,
	SUM(CASE WHEN churned = 'Churned' THEN 1 ELSE 0 END)Churned_users,
	ROUND(
	SUM(CASE WHEN churned = 'Churned' THEN 1 ELSE 0 END) *100/COUNT(*)
	)churn_rate
FROM users
GROUP BY issued_ticket;

                                                                                                                Q10.Business question
                                                                                                     How does active seat usage impact retention?
Query
SELECT
	CASE WHEN active_seats BETWEEN 0 AND 15 THEN 'low_active_seats_usage'
	WHEN active_seats BETWEEN 16 AND 50 THEN 'mid_active_seats_usage'
	ELSE 'high_active_seats_usage'
	END AS active_seats_users,
	COUNT(*)total_users,
	SUM(CASE WHEN churned ='Churned' THEN 1 ELSE 0 END)churned_users,
	SUM(CASE WHEN churned ='Active' THEN 1 ELSE 0 END)active_users,
	ROUND(
	SUM(CASE WHEN churned = 'Churned' THEN 1 ELSE 0 END) *100.0/COUNT(*),2
	)churn_rate
FROM user_monthly
GROUP BY active_seats_users;
