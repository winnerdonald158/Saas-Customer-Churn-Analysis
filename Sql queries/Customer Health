	CASE WHEN nps_score BETWEEN 0.00 AND 3.00 THEN 'low_rate'
	WHEN nps_score BETWEEN 4.00 AND 6.00 THEN 'moderate_rate'
	ELSE 'high_rate'
	END AS users_satisfaction,
